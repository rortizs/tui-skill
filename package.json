{
  "name": "tui-skills",
  "version": "0.1.0",
  "description": "External skill management layer for AI coding clients.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rortizs/tui-skill.git"
  },
  "engines": {
    "node": ">=20"
  },
  "type": "module",
  "bin": {
    "tui-skills": "./dist/cli/index.js"
  },
  "files": [
    "dist",
    "docs",
    "README.md"
  ],
  "scripts": {
    "clean": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\"",
    "prebuild": "npm run clean",
    "build": "tsc -p tsconfig.json",
    "prepack": "npm run build",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.test.json",
    "test": "vitest run"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "typescript": "^5.7.2",
    "vitest": "^4.1.8"
  }
}
